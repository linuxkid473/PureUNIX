diff --git a/gio/gtask.c b/gio/gtask.c
index 45006c2..bd065c0 100644
--- a/gio/gtask.c
+++ b/gio/gtask.c
@@ -1625,6 +1625,61 @@ task_thread_cancelled_disconnect_notify (gpointer  task,
   g_object_unref (task);
 }
 
+/* PureUnix has no real background threading at all -- pthread_create()
+ * (which g_thread_new()/GThreadPool worker threads are ultimately built
+ * on, see user/newlib_syscalls.c's own pthread section comment) runs its
+ * entry point synchronously, inline, before returning. GLib's shared
+ * task_pool is a real, persistent keep-alive thread pool: the first push
+ * to an empty pool spawns a real worker thread whose own loop
+ * (g_thread_pool_thread_proxy -> g_thread_pool_wait_for_new_task ->
+ * g_async_queue_pop on an otherwise-empty queue) blocks forever waiting
+ * for the *next* task after finishing this one -- a real, deliberate,
+ * infinite "keep this thread alive for reuse" design. Running that
+ * synchronously deadlocks the very first g_task_run_in_thread() caller
+ * forever (reproduced directly: g_file_monitor_file()'s polling
+ * fallback calls g_file_query_info_async(), which is exactly this path).
+ *
+ * An *inline* synchronous call (the first real version of this fix) is
+ * NOT correct either, and was found the hard way via a real, reproduced
+ * crash: g_task_run_in_thread() is always called from *inside* a real
+ * public GIO entry point (g_file_query_info_async(), etc.) that the
+ * caller expects to return before any callback fires -- exactly like
+ * every other real async API. Running the task's own worker function AND
+ * its completion callback fully inline, reentrantly, before that outer
+ * call has even returned, meant the callback could run (and free/replace
+ * a GCancellable or GFile the caller was still in the middle of storing
+ * a reference to) *before* the caller's own bookkeeping for this exact
+ * operation had finished -- observed as real, intermittent
+ * g_object_ref()/g_file_query_info_async() "assertion ... failed"
+ * warnings immediately followed by a genuine use-after-free page fault
+ * inside PCManFM-Qt's own folder-listing code (docs/pcmanfm-port.md's
+ * dated entry). Deferred-to-next-main-loop-iteration execution (a real
+ * GSource attached to the task's own thread-default context, task->context,
+ * exactly what g_task_return() itself already uses to schedule the
+ * *completion* callback) fixes this the same way this project's own
+ * Fm::Job::runAsync() fix (third_party/libfm-qt/patches/0006,
+ * QTimer::singleShot(0, ...) instead of inline synchronous execution)
+ * already fixed the identical class of problem one layer up the stack --
+ * the caller always gets to finish returning first, just like a real
+ * background thread would give it, before anything can call back in. */
+static gboolean
+g_task_run_in_thread_idle_cb (gpointer user_data)
+{
+  GTask *task = user_data;
+  g_task_thread_pool_thread (task, NULL);
+  return G_SOURCE_REMOVE;
+}
+
+static void
+g_task_run_in_thread_synchronously (GTask *task)
+{
+  GSource *source = g_idle_source_new ();
+  g_object_ref (task);
+  g_source_set_callback (source, g_task_run_in_thread_idle_cb, task, NULL);
+  g_source_attach (source, task->context);
+  g_source_unref (source);
+}
+
 static void
 g_task_start_task_thread (GTask           *task,
                           GTaskThreadFunc  task_func)
@@ -1646,7 +1672,7 @@ g_task_start_task_thread (GTask           *task,
         {
           task->thread_cancelled = task->thread_complete = TRUE;
           TRACE (GIO_TASK_AFTER_RUN_IN_THREAD (task, task->thread_cancelled));
-          g_thread_pool_push (task_pool, g_object_ref (task), NULL);
+          g_task_run_in_thread_synchronously (task);
           return;
         }
 
@@ -1667,7 +1693,7 @@ g_task_start_task_thread (GTask           *task,
 
   if (g_private_get (&task_private))
     task->blocking_other_task = TRUE;
-  g_thread_pool_push (task_pool, g_object_ref (task), NULL);
+  g_task_run_in_thread_synchronously (task);
 }
 
