########################################################################
# PureUNIX's own terminfo source entry — describes drivers/vga.c's ANSI/
# VT100-subset escape-sequence interpreter and drivers/tty.c's keyboard
# input encoding *exactly*, capability by capability. This is a new
# terminal description, not a patch to any upstream ncurses file: adding
# support for a new terminal type is always done this way (upstream's own
# misc/terminfo.src is nothing but ~4000 entries just like this one).
#
# tools/build-ncurses.sh appends this into a scratch copy of ncurses'
# misc/terminfo.src before configuring the cross build with
# --with-fallbacks=pureunix,dumb, compiling this entry straight into
# libncurses.a (see --disable-database in that script — PureUNIX has no
# terminfo database on its filesystem at all, so ncurses can *only* ever
# resolve TERM=pureunix through this compiled-in fallback).
#
# Every capability below traces to a specific drivers/vga.c or
# drivers/tty.c code path — see docs/ncurses-port.md for the full mapping.
# No capability is declared unless this port actually implements it, and a
# missing one is simply *omitted* rather than explicitly cancelled with a
# trailing `@`: omitting compiles to a plain "absent" (NULL) capability,
# which every ncurses code path treats as "this terminal doesn't have it";
# `@`-cancellation instead compiles to a distinct "explicitly absent"
# sentinel (`(char *)-1` for strings) meant for un-setting something a
# `use=` parent entry had. This entry never uses `use=`, so nothing is
# ever inherited to cancel — an earlier draft used `@` here anyway out of
# habit and crashed ncurses' own newterm() startup path (lib_newterm.c's
# SGR0_TEST macro checks a string capability against 0/NULL but not
# against the -1 cancellation sentinel, so `rmul@` made it call
# strcmp((char *)-1, ...) — see docs/ncurses-port.md's "Platform work"
# section).
########################################################################
pureunix|PureUNIX native framebuffer/VGA console (drivers/vga.c),
	am, bce,
	colors#16, cols#80, it#0, lines#24, pairs#256,
	bel=^G,
	bold=\E[1m,
	civis=\E[?25l,
	clear=\E[H\E[2J,
	cnorm=\E[?25h,
	cr=^M,
	csr=\E[%i%p1%d;%p2%dr,
	cub=\E[%p1%dD, cub1=\E[D,
	cud=\E[%p1%dB, cud1=\E[B,
	cuf=\E[%p1%dC, cuf1=\E[C,
	cup=\E[%i%p1%d;%p2%dH,
	cuu=\E[%p1%dA, cuu1=\E[A,
	dl=\E[%p1%dM, dl1=\E[M,
	ed=\E[J,
	el=\E[K, el1=\E[1K,
	home=\E[H,
	il=\E[%p1%dL, il1=\E[L,
	ind=\ED,
	is2=\E[m\E[?25h,
	kbs=\177,
	kcub1=\E[D, kcud1=\E[B, kcuf1=\E[C, kcuu1=\E[A,
	kdch1=\E[3~, kend=\E[F, khome=\E[H,
	kf1=\EOP, kf2=\EOQ, kf3=\EOR, kf4=\EOS,
	kf5=\E[15~, kf6=\E[17~, kf7=\E[18~, kf8=\E[19~,
	kf9=\E[20~, kf10=\E[21~, kf11=\E[23~, kf12=\E[24~,
	knp=\E[6~, kpp=\E[5~,
	nel=^J,
	op=\E[39;49m,
	rc=\E8,
	rev=\E[7m,
	ri=\EM,
	rmso=\E[27m,
	sc=\E7,
	setab=\E[%?%p1%{8}%<%t4%p1%d%e10%p1%{8}%-%d%;m,
	setaf=\E[%?%p1%{8}%<%t3%p1%d%e9%p1%{8}%-%d%;m,
	sgr0=\E[m,
	smso=\E[7m,
