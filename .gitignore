build/
*.o
*.d
*.elf
# Deliberately vendored prebuilt binary (see third_party/busybox/README.md
# and tools/build-busybox.sh) — not a build artifact, exempt from the *.elf
# rule above.
!third_party/busybox/busybox.elf
graphify-out/

__pycache__/

# extra-files/: local drop-in files staged onto the OS image by the
# Makefile's EXTRA_FILES_ARGS (see Makefile's own comment above $(DISK2))
# -- personal, not version-controlled.
extra-files/*
!extra-files/.gitkeep

# macOS
.DS_Store

# Claude Buddy
claude-buddy/
.wip-reference/
